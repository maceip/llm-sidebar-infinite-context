{
  "name": "llm-sidebar-with-context",
  "version": "1.0.0",
  "description": "This chrome extension allows you to interact with LLMs in a sidebar and use multiple tabs as context when doing so",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build": "node build-scripts/build.js",
    "build:extension": "node build-scripts/build.js",
    "build:native:host": "cargo +stable build --manifest-path native/host/Cargo.toml",
    "build:native:installer": "cargo +stable build --manifest-path native/installer/Cargo.toml",
    "build:native:overlay": "cargo +stable build --manifest-path native/overlay-companion/Cargo.toml",
    "build:native": "npm run build:native:host && npm run build:native:installer && npm run build:native:overlay",
    "build:package": "npm run build:extension && npm run build:native && npm run pack-crx:dev && node build-scripts/prepare-installer-assets.js",
    "installer:prepare": "npm run build:package",
    "installer:install": "npm run build:package && node build-scripts/run-installer.js install",
    "installer:uninstall": "node build-scripts/run-installer.js uninstall",
    "type-check": "tsc",
    "test:native-companion": "node test-harness/native-companion/run-harness.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack-crx": "node build-scripts/pack-crx.js",
    "pack-crx:dev": "node build-scripts/pack-crx.js --generate-key",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google/llm-sidebar-with-context.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/google/llm-sidebar-with-context/issues"
  },
  "homepage": "https://github.com/google/llm-sidebar-with-context#readme",
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.1",
    "motion": "^12.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/cli": "^4.1.4",
    "@types/chrome": "^0.1.35",
    "@types/node": "^25.0.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.4",
    "esbuild": "^0.27.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.17",
    "yazl": "^3.3.1"
  }
}
